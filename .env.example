# DevGuardian AI Environment Variables
# Copy this file to .env and fill in your actual values

# =============================================================================
# SECURITY CREDENTIALS (REQUIRED)
# =============================================================================
POSTGRES_PASSWORD=devguardian123
SECRET_KEY=your-super-secret-key-at-least-32-characters-long

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=devguardian_ai
DB_USERNAME=devguardian
DB_PASSWORD=devguardian123

# =============================================================================
# REDIS CONFIGURATION (Optional)
# =============================================================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME=DevGuardian AI
APP_ENV=local
DEBUG=true

# =============================================================================
# JWT SETTINGS
# =============================================================================
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
HOST=127.0.0.1
PORT=8002

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
VITE_API_BASE_URL=http://127.0.0.1:8002

# =============================================================================
# SECURITY BEST PRACTICES
# =============================================================================
# 1. Never commit .env files to version control
# 2. Use strong, unique passwords (minimum 32 characters)
# 3. Rotate keys and passwords regularly
# 4. Use different credentials for each environment

# =============================================================================
# QUICK START
# =============================================================================
# 1. Copy and configure environment:
#    cp .env.example .env
#
# 2. Start PostgreSQL:
#    docker run -d -e POSTGRES_DB=devguardian_ai -e POSTGRES_USER=devguardian -e POSTGRES_PASSWORD=devguardian123 -p 5433:5432 postgres:16
#
# 3. Start backend:
#    cd backend && pip install -r requirements.txt && uvicorn app.main:app --port 8002
#
# 4. Start frontend:
#    cd frontend && npm install && npm run dev